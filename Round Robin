#include <iostream>
#include <vector>
#include <queue>
#include <iomanip>
using namespace std;

struct Process {
    int id;
    int arrival_time;
    int burst_time;
    int remaining_time;
    int completion_time;
    int turnaround_time;
    int waiting_time;
};

int main() {

    int n, quantum;
    cin >> quantum >> n;

    vector<Process> p(n);

    for (int i = 0; i < n; i++) {
        cin >> p[i].arrival_time >> p[i].burst_time;
        p[i].id = i + 1;
        p[i].remaining_time = p[i].burst_time;
        p[i].completion_time = 0;
    }

    queue<int> q;
    vector<bool> inQueue(n, false);

    int current_time = 0;
    int completed = 0;

    cout << "Queue updates:\n";

    while (completed < n) {

        for (int i = 0; i < n; i++) {
            if (p[i].arrival_time <= current_time &&
                !inQueue[i] &&
                p[i].remaining_time > 0) {

                q.push(i); 
                inQueue[i] = true;
            }
        }

        
        if (q.empty()) {  
            cout << "[ Empty ]\n";
            current_time++;
            continue;
        }
        queue<int> temp = q;  
        cout << "[ ";
        while (!temp.empty()) {
            cout << "P" << p[temp.front()].id;
            temp.pop();
            if (!temp.empty()) cout << ", ";
        }
        cout << " ]\n";

        
        int i = q.front();
        q.pop();

         
        int exec = min(quantum, p[i].remaining_time); 
        current_time += exec;
        p[i].remaining_time -= exec; 
        
        for (int j = 0; j < n; j++) {
            if (p[j].arrival_time <= current_time &&
                !inQueue[j] &&   
                p[j].remaining_time > 0) {

                q.push(j);
                inQueue[j] = true;
            }
        }

        
        if (p[i].remaining_time > 0) {
            q.push(i);    
        }
        else {
            p[i].completion_time = current_time;
            completed++;    
        }
    }

    cout << "[ Empty ]\n";

    
    float total_waiting = 0;

    cout << "Process Completion Time Turnaround Time Waiting Time\n";

    for (int i = 0; i < n; i++) {
        p[i].turnaround_time = p[i].completion_time - p[i].arrival_time;
        p[i].waiting_time = p[i].turnaround_time - p[i].burst_time;

        total_waiting += p[i].waiting_time;

        cout << "P" << p[i].id << " "
            << p[i].completion_time << " "
            << p[i].turnaround_time << " "
            << p[i].waiting_time << "\n";
    }

    cout << fixed << setprecision(1);
    cout << "Average Waiting Time: " << total_waiting / n << endl;

    return 0;
}
